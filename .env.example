# Required
GROQ_API_KEY=your_groq_api_key_here
SECRET_KEY=generate_with__python -c 'import secrets; print(secrets.token_urlsafe(32))'

# Optional (defaults shown)
# DATABASE_URL=sqlite+aiosqlite:///./sidekick.db
# For Supabase, use the "Connection pooling" string from Project Settings → Database.
# Both forms work — postgres:// and postgresql:// get auto-rewritten to postgresql+asyncpg://.
# Example (pooler, port 6543, transaction mode):
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# GROQ_MODEL=llama-3.3-70b-versatile
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
# CORS_ORIGINS=http://localhost:5173
